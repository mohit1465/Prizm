{
  "appId": "com.example.Prizm",
  "productName": "Prizm",
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,test,__tests__}",
    "!**/node_modules/.bin"
  ],
  "win": {
    "target": "portable",
    "icon": "assets/Prizm_Logo.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
